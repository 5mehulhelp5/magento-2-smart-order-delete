<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Sales::sales">
                    <resource id="Thinkbeat_SmartOrderDelete::root" title="Smart Order Delete" sortOrder="100">
                        <resource id="Thinkbeat_SmartOrderDelete::delete" title="Delete Orders (Mass Action)" sortOrder="10"/>
                        <resource id="Thinkbeat_SmartOrderDelete::trash" title="Trash Bin" sortOrder="20"/>
                        <resource id="Thinkbeat_SmartOrderDelete::restore" title="Restore Orders" sortOrder="30"/>
                        <resource id="Thinkbeat_SmartOrderDelete::purge" title="Purge Trash" sortOrder="40"/>
                        <resource id="Thinkbeat_SmartOrderDelete::logs" title="Deletion Logs" sortOrder="50"/>
                    </resource>
                </resource>
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="Thinkbeat_SmartOrderDelete::config" title="Smart Order Delete Configuration" />
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
