<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="thinkbeat_smartdelete_auto_delete" instance="Thinkbeat\SmartOrderDelete\Cron\AutoDelete" method="execute">
            <config_path>thinkbeat_smartdelete/auto_delete/cron_expr</config_path>
        </job>
        <job name="thinkbeat_smartdelete_auto_purge" instance="Thinkbeat\SmartOrderDelete\Cron\AutoPurge" method="execute">
            <schedule>0 2 * * *</schedule>
        </job>
    </group>
</config>
