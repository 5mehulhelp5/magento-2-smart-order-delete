<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="thinkbeat" translate="label" sortOrder="200">
            <label>Thinkbeat</label>
        </tab>
        <section id="thinkbeat_smartdelete" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>Smart Order Delete</label>
            <tab>thinkbeat</tab>
            <resource>Thinkbeat_SmartOrderDelete::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Configuration</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Module Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="soft_delete_enabled" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Trash Bin (Soft Delete)</label>
                    <comment>If No, orders are permanently deleted immediately.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
            <group id="email_notification" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Email Notification</label>
                <field id="enable" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Email can be sent only when orders are deleted automatically by schedule.</comment>
                </field>
                <field id="sender" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Sender</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Identity</source_model>
                </field>
                <field id="template" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Email Template</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Template</source_model>
                </field>
                <field id="recipient" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Send To</label>
                    <comment>Separated by comma(s)</comment>
                </field>
            </group>
            <group id="auto_delete" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="0">
                <label>Automatic Delete Configuration</label>
                <field id="enabled" translate="label" type="select" sortOrder="5" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Enable Automatic Delete</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="schedule" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Schedule For</label>
                    <source_model>Magento\Cron\Model\Config\Source\Frequency</source_model>
                    <backend_model>Thinkbeat\SmartOrderDelete\Model\Config\Backend\Cron</backend_model>
                    <comment>Set up the schedule in which orders are deleted automatically. (Uses default System Cron)</comment>
                </field>
                 <field id="time" translate="label" sortOrder="20" type="time" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Start Time</label>
                    <depends>
                        <field id="schedule">D</field> <!-- Depends on Daily, but actually Frequency uses D, W, M -->
                    </depends>
                </field>
                <field id="retention_period" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Excluded Period (Retention Days)</label>
                    <validate>validate-digits</validate>
                    <comment>Orders older than this many days (e.g., 7) will be candidates for deletion.</comment>
                </field>
                <field id="order_status" translate="label" type="multiselect" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="0">
                    <can_be_empty>1</can_be_empty>
                    <label>Order Status</label>
                    <source_model>Magento\Sales\Model\Config\Source\Order\Status</source_model>
                </field>
                <field id="customer_groups" translate="label" type="multiselect" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="0">
                    <can_be_empty>1</can_be_empty>
                    <label>Customer Group(s)</label>
                    <source_model>Thinkbeat\SmartOrderDelete\Model\Config\Source\CustomerGroup</source_model>
                </field>
                <field id="store_ids" translate="label" type="multiselect" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="0">
                    <can_be_empty>1</can_be_empty>
                    <label>Store View(s)</label>
                    <source_model>Magento\Store\Model\System\Store</source_model>
                </field>
                <field id="shipping_countries" translate="label" type="multiselect" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="0">
                    <can_be_empty>1</can_be_empty>
                    <label>Shipping Countries</label>
                    <source_model>Magento\Directory\Model\Config\Source\Country</source_model>
                </field>
                <field id="max_order_total" translate="label" type="text" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Order Total</label>
                    <validate>validate-number</validate>
                    <comment>Less than or equal this amount</comment>
                </field>
                <field id="run_manually" translate="label" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="0">
                     <label>Run Manually</label>
                     <frontend_model>Thinkbeat\SmartOrderDelete\Block\Adminhtml\System\Config\RunManually</frontend_model>
                </field>
            </group>
        </section>
    </system>
</config>
